# Rust build artifacts (root and nested, e.g. src-tauri/target/)
target/

# Node.js
node_modules/

# Vite / frontend build output
dist/

# Tauri Apple bundle generated files
src-tauri/gen/apple/

# Temporary dev files (.tmp/ is used for download cache etc.)
.tmp/

# macOS
.DS_Store
**/.DS_Store

# Brainstorming session artifacts
.superpowers/

# Local fixture bundles (large, environment-specific)
example_data/

# Playwright MCP working directory
.playwright-mcp/

# SvelteKit sync output
.svelte-kit/

# Tauri frontendDist (regenerated by `vite build`)
build/

# Native QA run artifacts (regenerated on every Sisyphus run)
.sisyphus/evidence/native-qa/

# Local OpenCode skill cache
.opencode/skills/
